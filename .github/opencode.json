{
	"$schema": "https://opencode.ai/config.json",
	"autoshare": false,
	"autoupdate": false,
	"model": "opencode/deepseek-v4-flash-free",
	"plugin": [
		"opencode-skills-collection@latest",
		"superpowers@git+https://github.com/obra/superpowers.git",
		[
			"opencode-goal-plugin",
			{
				"maxTurns": 30,
				"maxDurationMs": 9000000,
				"maxTokens": 20000000,
				"maxRecentMessages": 150,
				"noProgressTurnsBeforePause": 6,
				"maxPromptFailures": 6
			}
		]
	],
	"formatter": {
		"nixfmt": {
			"command": ["nixfmt", "$FILE"],
			"extensions": [".nix"]
		},
		"rustfmt": {
			"command": ["rustfmt", "--config", "skip_children=true", "$FILE"],
			"extensions": [".rs"]
		},
		"shfmt": {
			"command": ["shfmt", "-w", "$FILE"],
			"extensions": ["*.sh", "*.bash", "*.envrc", "*.envrc.*"]
		},
		"taplo": {
			"command": ["taplo", "format", "$FILE"],
			"extensions": ["*.toml"]
		},
		"yamlfmt": {
			"command": ["yamlfmt", "$FILE"],
			"extensions": ["*.yaml", "*.yml"]
		}
	},
	"permission": {
		"*": "allow"
	},
	"share": "disabled",
	"mcp": {
		"mcp-nixos": {
			"enabled": true,
			"type": "local",
			"command": ["mcp-nixos"]
		},
		"mcp-server-filesystem": {
			"enabled": true,
			"type": "local",
			"command": ["mcp-server-filesystem"]
		},
		"mcp-server-git": {
			"enabled": true,
			"type": "local",
			"command": ["mcp-server-git"]
		},
		"mcp-server-fetch": {
			"enabled": true,
			"type": "local",
			"command": ["mcp-server-fetch"]
		},
		"github": {
			"type": "local",
			"command": ["github-mcp-server"],
			"enabled": true,
			"environment": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GH_TOKEN}"
			}
		},
		"context7": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		},
		"grep_app": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.grep.app"
		},
		"desktop-commander": {
			"type": "local",
			"command": ["npx", "--yes", "@wonderwhy-er/desktop-commander@latest"],
			"enabled": true
		},
		"android-mcp": {
			"type": "local",
			"command": ["uvx", "--python", "3.13", "android-mcp"],
			"enabled": true
		},
		"sequential-thinking": {
			"type": "local",
			"command": [
				"npx",
				"--yes",
				"@modelcontextprotocol/server-sequential-thinking"
			],
			"enabled": true
		},
		"memory": {
			"type": "local",
			"command": ["npx", "--yes", "@modelcontextprotocol/server-memory"],
			"enabled": true
		},
		"web-search": {
			"type": "local",
			"command": ["npx", "--yes", "open-websearch@latest"],
			"enabled": true,
			"environment": {
				"SEARCH_MODE": "request",
				"DEFAULT_SEARCH_ENGINE": "duckduckgo"
			}
		}
	},
	"command": {
		"goal": {
			"description": "Set a session-scoped goal and auto-continue until complete.",
			"template": "$ARGUMENTS",
			"agent": "build"
		}
	}
}
